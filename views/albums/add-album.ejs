<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Album</title>
</head>
<body>
    <h1>Create Album</h1>
    <a href="/album/browse"><strong>Back to Main Page</strong></a><br><br>

    <form action="/album/create" method="POST">
        <table border="1">
            Album Title:
            <br><input type="text" name="title" required><br><br>
            Album Description:<br>
            <textarea id="description" name="description" rows="4" cols="25"></textarea><br><br>
            Album Release Year:
            <br><input type="number" name="year" required><br><br>

            Insert Songs:<br>
            <input type="text" id="songSearch" placeholder="Search by song title..." autocomplete="off" cols="25" style="width:200px"><br>
            <ul id="songResults" style="list-style:none; padding:0; margin:0; border:1px solid #ccc; width:200px; display:none;"></ul>
            <div id="selectedSongs"></div>
            <input type="hidden" name="songs" id="songsHidden" required><br>

        <br>
        <button type="submit">Create Album</button>
        </table>
    </form>

    <br><br>
    <% if(msg!="" ){ %>
        <p><strong><%= msg %></strong></p>
    <% } %>

    <script src="/javascript/song-search.js"></script>
</body>
</html>
