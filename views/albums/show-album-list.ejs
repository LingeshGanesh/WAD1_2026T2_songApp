<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Browse Playlists</title>
    <link rel="stylesheet" href="/css/album-dark.css">
</head>

<body>
    <%- include("../navbar-user") %>
        <h1>Browse Albums</h1>
        <button type="button"><a href="/album/create"><strong>Create Album</strong></a><br><br></button><br><br>
        <% if (allAlbums && allAlbums.length ) { %>
            <table border="1">
                <tr>
                    <th>Album Title</th>
                    <th>Year Created</th>
                    <th>Artist</th>
                </tr>
                <% allAlbums.forEach(album=> { %>
                    <tr>
                        <td><a href="/album/<%= album._id %>"><%= album.title %></a></td>
                        <td><%= album.yearReleased %></td>
                        <td><%= album.createdBy ? album.createdBy.username : 'Unknown' %></td>
                    </tr>
                <% }) %>
            </table>
            <% } else { %>
                <p>No albums yet.</p>
            <% } %>
    <%- include("../footer") %>
</body>
</html>