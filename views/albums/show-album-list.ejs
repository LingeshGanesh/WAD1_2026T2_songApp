<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Browse Playlists</title>
    <link rel="stylesheet" href="/css/album-dark.css">
    <link rel="stylesheet" href="/css/events-styles.css">
</head>

<body>
    <%- include('../navbar-user') %>

    <div class="album-content">
    <h1>Browse Albums</h1>
    <button type="button"><a href="/album/create"><strong>Create Album</strong></a><br><br></button><br><br>
    <input type="text" id="albumSearch" placeholder="Search by album title..."><br><br>

<% if (allAlbums && allAlbums.length) { %>
    <table border="1" id="albumTable">
        <tr>
            <th>Album Title</th>
            <th>Year Created</th>
            <th>Artist</th>
        </tr>
        <% allAlbums.forEach(album => { %>
            <tr class="album-row">
                <td><a href="/album/<%= album._id %>"><%= album.title %></a></td>
                <td><%= album.yearReleased %></td>
                <td><%= album.createdBy ? album.createdBy.username : 'Unknown' %></td>
            </tr>
        <% }) %>
    </table>
    <p id="noResults" style="display:none;">No albums found.</p>
<% } else { %>
    <p>No albums yet.</p>
<% } %>

<script>
    document.getElementById('albumSearch').addEventListener('input', function () { // fires everytime user type/delete something
        const q = this.value.toLowerCase(); // get the current text in search box and makes it case insensitive
        const rows = document.querySelectorAll('.album-row'); // selects all table rows with class album row rendered by EJS
        let visible = 0;

        rows.forEach(row => { // loops through every album
            const title = row.querySelector('td a').textContent.toLowerCase(); // gets the album title text from the link inside the first cell
            if (title.startsWith(q)) { // check for if title starts with what the user type
                row.style.display = ''; // if match, show the row
                visible++; // count the number of rows
            } else {
                row.style.display = 'none'; // if dont match, dont show the row
            }
        });

        // after looping through all rows, if visible is 0 means no rows match so it will show no albums found message. otherwise it is kept hidden
        document.getElementById('noResults').style.display = visible === 0 ? 'block' : 'none';
    });
</script>
    </div>
</body>
</html>