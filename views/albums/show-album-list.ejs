<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Browse Playlists</title>
    <link rel="stylesheet" href="/css/album-dark.css">
</head>

<body>
    <%- include('../navbar-user') %>
    <h1>Browse Albums</h1>
    <button type="button"><a href="/album/create"><strong>Create Album</strong></a><br><br></button><br><br>
    <input type="text" id="albumSearch" placeholder="Search by album title..."><br><br>

<% if (allAlbums && allAlbums.length) { %>
    <table border="1" id="albumTable">
        <tr>
            <th>Album Title</th>
            <th>Year Created</th>
            <th>Artist</th>
        </tr>
        <% allAlbums.forEach(album => { %>
            <tr class="album-row">
                <td><a href="/album/<%= album._id %>"><%= album.title %></a></td>
                <td><%= album.yearReleased %></td>
                <td><%= album.createdBy ? album.createdBy.username : 'Unknown' %></td>
            </tr>
        <% }) %>
    </table>
    <p id="noResults" style="display:none;">No albums found.</p>
<% } else { %>
    <p>No albums yet.</p>
<% } %>

<script>
    document.getElementById('albumSearch').addEventListener('input', function () {
        const q = this.value.toLowerCase();
        const rows = document.querySelectorAll('.album-row');
        let visible = 0;

        rows.forEach(row => {
            const title = row.querySelector('td a').textContent.toLowerCase();
            if (title.startsWith(q)) {
                row.style.display = '';
                visible++;
            } else {
                row.style.display = 'none';
            }
        });

        document.getElementById('noResults').style.display = visible === 0 ? 'block' : 'none';
    });
</script>
</body>
</html>