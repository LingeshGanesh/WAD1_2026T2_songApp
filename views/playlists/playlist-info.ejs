<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Browse Playlists</title>
    <style>
        table.pinfo th {
            text-align: left;
        }
    </style>
</head>
<body>
    <%- include("../navbar-user") %>
    <h1>Information for "<%= playlist.name %>"</h1>
    <h2>Created by: <%= playlist.owner? playlist.owner: "Unknown" %></h2>
    <p><%= playlist.description || "No description provided." %></p>
    <!-- Other information -->
    <table class="pinfo">
        <tr>
            <th>Genre</th>
            <th>:</th>
            <td><%= playlist.genre || "None" %></td>
        </tr>
        <tr>
            <th>Visibility</th>
            <th>:</th>
            <td><%= playlist.visibility %></td>
        </tr>
        <tr>
            <th>Creation Date</th>
            <th>:</th>
            <td><%= playlist.creationDate %></td>
        </tr>
    </table><br>
    <!-- Songs -->
    <table border="1">
        <tr>
            <th>No.</th>
            <th>Title</th>
            <th>Artist</th>
            <th>Duration</th>
        </tr>
        <% for (let i = 0; i < playlist.songs.length; i++) { %>
        <tr>
            <% const song = songsList[i] %>
            <th><%= (i + 1).toString().padStart(2, "0") %></th>
            <td><a href="/song/<%= song._id %>"><%= song.title %></a></td>
            <td><%= song.artist %></td>
            <td><%= songsDuration[i] %></td>
        </tr>
        <% } %>
    </table>
    <%- include("../footer") %>
</body>
</html>