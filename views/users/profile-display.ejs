<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/events-styles.css">
    <title>Display Profile</title>
</head>

<body>
    <%- include("../navbar-user") %>
        <div class="page-body">
            <a href="#" class="back-link" onclick="history.back(); return false;">← Back</a>
            <section class="profile-hero">
                <div class="profile-hero-avatar">
                    <img src="<%= user.profilePicture %>" alt="<%= user.username %>">
                </div>

                <div class="profile-hero-info">
                    <p class="profile-label">Profile</p>
                    <h1 class="profile-big-name">
                        <%= user.username %>
                    </h1>
                    <p class="profile-subtext">
                        <%= playlists.length %> Public Playlists
                    </p>

                    <div class="profile-links">
                        <a href="/user/showConnection?type=followers&id=<%= user._id %>">
                            <%= user.followers.length %> followers
                        </a>
                        <a href="/user/showConnection?type=following&id=<%= user._id %>">
                            <%= user.followings.length %> following
                        </a>
                    </div>

                    <form action="/user/<%= isFollowing ? 'unfollowUser' : 'followUser' %>" method="post">
                        <input type="hidden" name="targetUserId" value="<%= user._id %>">
                        <button type="submit" class="profile-follow-btn">
                            <%= isFollowing ? 'Following' : 'Follow' %>
                        </button>
                    </form>
                </div>
            </section>

            <section class="playlist-section">
                <h2>Public Playlists</h2>

                <% if (playlists.length> 0) { %>
                    <div class="playlist-grid">
                        <% playlists.forEach(playlist=> { %>
                            <% const thumbURL=playlist.thumbnailExt ?
                                `/image/playlist-thumb/${playlist._id}${playlist.thumbnailExt}`
                                : '/image/default-thumb.png' %>

                                <a href="/playlist/<%= playlist._id %>" class="playlist-card">
                                    <img src="<%= thumbURL %>" alt="<%= playlist.name %>">
                                    <span>
                                        <%= playlist.name %>
                                    </span>
                                </a>
                                <% }) %>
                    </div>
                    <% } else { %>
                        <div class="empty-state">No public playlists yet.</div>
                        <% } %>
            </section>
        </div>
</body>

</html>