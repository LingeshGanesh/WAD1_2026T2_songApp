<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>
    <!-- <link rel="stylesheet" href="/css/events-styles.css"> -->
</head>

<body>
    <%- include("../navbar-user") %>
        <h2>Welcome, <%= user.username %>!</h2>
        <a href="/user/search">Search Friends</a><br>
        <form action="/user/logout" method="post">
            <button type="submit">Log-Out</button>
        </form>

        <a href="/user/edit/">Edit personal info</a><br>
        <a href="/user/change-password/">Change Password</a><br>
        <a href="/user/delete/">Delete Account</a><br>
        <img src="<%=user.profilePicture%>" width="150"><br>
        <p>
            <%= user.followers.length %>
                <%- user.followers.length <=1 ? `<a
                    href="/user/showConnection?type=followers&id=${user._id}">follower</a>`
                    : `<a href="/user/showConnection?type=followers&id=${user._id}">followers</a>`
                    %>
        </p>

        <p>
            <%= user.followings.length %>
                <a href="/user/showConnection?type=following&id=<%= user._id %>">following</a>
        </p>
        Email: <%= user.email %> <br>

            <h3>Your Playlists</h3>

            <% if (playlists.length> 0) { %>
                <% playlists.forEach(playlist=> { %>
                    <p>
                        <a href="/playlist/<%= playlist._id %>">
                            <%= playlist.name %><br>
                                <% const thumbURL=playlist.thumbnailExt ?
                                    `/image/playlist-thumb/${playlist._id}${playlist.thumbnailExt}`
                                    : '/image/default-thumb.png' %>

                                    <img src="<%= thumbURL %>" width="120">

                        </a>

                    </p>
                    <% }) %>
                        <% } else { %>
                            <p>You have no playlists yet.</p>
                            <% } %>

            <h3>Your Reviews</h3>

            <% if (reviewsEntered && reviewsEntered.length > 0) { %>
                <table border="1" >
                    <thead>
                        <tr>
                            <th>Review No.</th>
                            <th>Song</th>
                            <th>Rating</th>
                            <th>Comment</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% reviewsEntered.forEach((review, idx) => { %>
                            <% let songTitle = review.songId; %>
                            <% for (let song of allSongs) { %>
                                <% if (song._id.toString() === review.songId.toString()) { %>
                                    <% songTitle = song.title; %>
                                    <% break; %>
                                <% } %>
                            <% } %>
                            <tr>
                                <td><%= idx + 1 %></td>
                                <td><%= songTitle %></td>
                                <td><%= review.rating %>/5</td>
                                <td><%= review.comment %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } else { %>
                <p>You have not entered any reviews yet.</p>
            <% } %>

        <h3>Your Alerts</h3>
        <form action="/user/clear-alerts" method="POST">
            <button type="submit">Clear All</button>
        </form>
        <% if (user.alerts && user.alerts.length > 0) { %>
            <% [...user.alerts].reverse().forEach(alert => { %>
                <p <%= !alert.read ? 'class="unread"' : '' %>>
                    <%= alert.message %>
                    <small><%= alert.createdAt.toLocaleDateString() %></small>
                </p>
            <% }) %>
        <% } else { %>
            <p>You have no alerts.</p>
        <% } %>
                                <%- include("../footer") %>
</body>

</html>