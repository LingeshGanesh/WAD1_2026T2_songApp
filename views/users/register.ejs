<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register</title>
</head>

<body>
    <h2>Sign up to start listening</h2>
    <form action="/user/register" method="post">
        <label for="avatar">Please choose a profile picture:</label><br>
        <% for (let i =1; i<=5; i++){ %>
            <input type="radio" name="avatar" value="/images/profilepic<%=i%>.jpg" required>
            <img src="/images/profilepic<%=i%>.jpg" alt="profilepic<%=i%>" width="150"><br>
        <% }%><br>
        
        <br><br>
        <label for="username">Username:</label><br>
        <input type="text" name="username" placeholder="Username" required>
        <br><br>
        <label for="email">Email:</label><br>
        <input type="email" name="email" placeholder="Email" required>
        <br><br>
        <label for="password">Password:</label><br>
        <input type="password" name="password" placeholder="Password" required><br><br>
        <button type="submit">Sign up</button>
    </form><br>
    Already have an account? <br><a href="/user/login">Login</a>
</body>
</html>