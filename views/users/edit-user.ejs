<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit User Details</title>
    <link rel="stylesheet" href="/css/events-styles.css">
</head>

<body class="auth-page">
    <div class="auth-shell">
        <a href="/user/profile" class="back-link auth-back-link">Back</a>
        <h1 class="auth-title">Edit your profile</h1>

        <form action="/user/update" method="post" class="auth-form">
            <div class="avatar-picker-card">
                <p class="avatar-picker-title">Choose a profile picture</p>

                <div class="avatar-grid">
                    <% for (let i=1; i <=5; i++) { %>
                        <div class="avatar-option">
                            <label>
                                <input type="radio" name="newAvatar" value="/image/profilepic<%= i %>.jpg"
                                    <%=(formData?.newAvatar || user.profilePicture)==='/image/profilepic' + i + '.jpg'
                                    ? 'checked' : '' %>>
                                <img src="/image/profilepic<%= i %>.jpg" alt="Avatar <%= i %>">
                                <span>Avatar <%= i %></span>
                            </label>
                        </div>
                        <% } %>
                </div>
            </div>

            <label for="newUsername">Username</label>
            <input id="newUsername" type="text" name="newUsername" placeholder="Username"
                value="<%= formData?.newUsername || user.username %>" required>

            <label for="newEmail">Email</label>
            <input id="newEmail" type="email" name="newEmail" placeholder="Email"
                value="<%= formData?.newEmail || user.email %>" required>

            <button type="submit" class="auth-submit">Update</button>

            <% if (errors && errors.length> 0) { %>
                <ul class="auth-errors">
                    <% errors.forEach(err=> { %>
                        <li>
                            <%= err %>
                        </li>
                        <% }) %>
                </ul>
                <% } %>
        </form>
    </div>
</body>

</html>