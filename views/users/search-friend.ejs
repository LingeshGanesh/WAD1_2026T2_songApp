<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Search friend</title>
</head>

<body>
    <a href="/user/profile">Back</a><br><br>
    <h2>Search friends</h2>
    <form action="/user/search-friend" method="get">
        <input type="text" name="query" placeholder="Search friends" value="<%=query%>">
        <button type="submit">Search</button>
    </form>
    <br>
    <%if(result && result.length>0){%>
        <table border="1">
            <tr>
                <th>Username</th>
                <th>Action</th>
            </tr>

            <% result.forEach(user=> { %>
                <tr>
                    <td>
                        <%= user.username %>
                    </td>
                    <td><a href="/user/addFriend/<%= user._id %>">Add</a></td>
                </tr>
                <% }) %>
        </table>
        <%}else if(errors && errors.length>0){%>
            <% errors.forEach(error=>{%>
                    <ul style="color: red;">
                        <li><%=error%></li>
                    </ul>
                <%})%>
                    <%}%>
</body>

</html>