<!DOCTYPE html>
<html>

<head>
    <title>Change your password</title>
</head>

<body>
    <a href="/user/profile">Back</a>
    <h2>Change your password</h2>

    <form action="/user/change-password" method="post">
        <label for="password">Current password:</label><br>
        <input type="password" name="currentPassword" value="<%=formData.currentPassword%>" required><br><br>
        <label for="newPassword">New password:</label><br>
        <input type="password" name="newPassword" value="<%=formData.newPassword%>"required><br>

        <ul style="color: red;">
            <li>Password must be min 8 characters long</li>
            <li>Include at least one uppercase letter (A-Z)</li>
            <li>Include at least one lowercase letter (a-z)</li>
            <li>Include at least one number (0-9)</li>
            <li>Include at least one special character (@ # $ % ^ & ! ?)</li>
            <li>No spaces allowed</li>
        </ul>

        <label for="cfmPassword">Repeat new password:</label><br>
        <input type="password" name="cfmPassword" value="<%=formData.cfmPassword%>" required><br><br>

        <button type="submit">Set new password</button>
    </form>
    <% if(errors && errors.length >0) {%>
        <ul style="color: red;">
        <% errors.forEach(error=>{%>
            <li><%=error%></li>
        <%})%>
        </ul>
    <%}%>
</body>

</html>