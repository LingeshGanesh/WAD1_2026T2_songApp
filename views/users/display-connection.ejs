<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Display connections</title>
    <link rel="stylesheet" href="/css/events-styles.css">
</head>

<body>
    <div class="page-body">
        <a href="#" class="back-link" onclick="history.back(); return false;">← Back</a>
        <h2>
            <%= type==='followers' ? 'Followers' : 'Following' %>
                of User: <%= user ? user.username : '' %>
        </h2>

        <% if (errors && errors.length> 0) { %>
            <ul class="auth-errors">
                <% errors.forEach(err=> { %>
                    <li>
                        <%= err %>
                    </li>
                    <% }) %>
            </ul>
            <% } %>

                <% if (list.length===0) { %>
                    <p class="empty-state">No <%= type %> found</p>
                    <% } else { %>
                        <div class="connections-grid">
                            <% list.forEach(user=> { %>
                                <a href="<%= user._id.equals(currentUserId) 
                                ? '/user/profile' 
                                : `/user/display-profile?id=${user._id}` %>" class="profile-card">
                                    <div class="avatar-wrapper">
                                        <img src="<%= user.profilePicture %>" alt="<%= user.username %>">
                                    </div>
                                    <span class="profile-username">
                                        <%= user.username %>
                                    </span>
                                </a>
                                <% }) %>
                        </div>
                        <% } %>
    </div>
</body>

</html>