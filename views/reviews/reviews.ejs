<!DOCTYPE html>
<!-- individual song reviews page -->
<html>
<head>
  <title>Reviews</title>
  <style>
    body { background-color: black; color: white; }
    a { color: rgb(46, 162, 108); }
  </style>
</head>
<body>
  <%- include('../navbar-user') %>

  <a href="/homepage"><strong>Back to Main Page</strong></a><br>
  <a href="/songs/browse"><strong>Back to Browse Songs</strong></a><br><br>

  <h1><u>Song to Review: <%= songTitle %></u></h1>

  <!-- CREATE FORM -->
  <h3>Add Your Reviews Here</h3>
  <form action="/reviews/create/<%= songId %>" method="POST">

    Rating (1-5): <input type="number" name="rating" min="1" max="5" /><br>

    Comment: <input type="text" name="comment" /><br>

    <button type="submit">Submit</button>
  </form>

  <!-- display errors if have -->
  <% if(error) { %>
    <p><%= error %></p>
  <% } %>

  <!-- display reviews -->
  <h3><u>Review List:</u></h3>

    <!-- if no reviews -->
    <% if (!reviews || reviews.length === 0) { %>
      <%= output %>
    <br>
    <!-- if got reviews -->
    <% } else { %>

    <h4><%= totalReviews %> review(s) found.</h4>

  <ol start="<%= ((page || 1) - 1) * 5 + 1 %>">

      <% reviews.forEach(function(review) { %>
      <li>

        <strong>Username: <%= review.userName %></strong><br>

        Rating: <%= review.rating %><br>

        Comment: <%= review.comment %><br>

        Created At: <%= review.createdAt.toLocaleString() %><br> 

        <!-- UPDATE FORM (only if user owns the review) -->
        <% if (locals.currentUser && review.userId.toString() === locals.currentUser._id.toString()) { %>
        <form action="/reviews/update/<%= songId %>" method="POST">

          <input type="hidden" name="reviewId" value="<%= review._id %>" />

          <input type="number" name="rating" min="1" max="5" placeholder="New Rating" style="width: 15ch;" />

          <input type="text" name="comment" placeholder="New Comment" style="width: 15ch;" />
          <button type="submit">Update</button>
        </form>


        <!-- DELETE FORM (only if user owns the review) -->
        <form action="/reviews/delete/<%= songId %>" method="POST">

          <input type="hidden" name="reviewId" value="<%= review._id %>" />
          <br>
          <button type="submit">Delete</button>
        </form>
        <% } %>
      </li>
      <br>
    <% }) %>
    <% } %>

  </ol>

  <!-- Pagination controls - only show if multiple pages exist -->
  <% if (totalPages > 1) { %>
  <div>
    <!-- Previous page link - only show if not on first page -->
    <% if (page > 1) { %>
      <a href="/reviews/<%= songId %>?page=<%= page - 1 %>">Previous</a>
    <% } %>
    <!-- Current page indicator -->
    Page <%= page %> of <%= totalPages %>
    <!-- Next page link - only show if not on last page -->
    <% if (page < totalPages) { %>
      <a href="/reviews/<%= songId %>?page=<%= page + 1 %>">Next</a>
    <% } %>
  </div>
  <% } %>

</body>
</html>