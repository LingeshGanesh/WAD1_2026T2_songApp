<!DOCTYPE html>
<!-- All Song Reviews Page - Shows reviews for all songs -->
<html>
<head>
  <title>All Reviews</title>
</head>
<body>
  <!-- Include the user navbar at the top of the page -->
  <%- include('../navbar-user') %>

  <h1><u>Review List:</u></h1>

  <!-- Check if there are no reviews to display -->
  <% if (!reviews) { %>
    <%= output %>
    <br>
  <% } else { %>

    <!-- Display total number of reviews found -->
    <h4><%= totalReviews %> review(s) found.</h4>

    <!-- Ordered list for reviews, starting number based on current page -->
    <ol start="<%= ((page || 1) - 1) * 5 + 1 %>">

      <!-- Loop through all songs -->
      <% songs.forEach(function(song) { %>

        <!-- Loop through all reviews -->
        <% reviews.forEach(function(review) { %>

          <!-- Only display review if it matches the current song -->
          <% if (review.songId.toString() === song._id.toString()) { %>
            <li>
              <strong>Song: <%= song.title %></strong><br>
              <strong>Username: <%= review.userName %></strong><br>
              Rating: <%= review.rating %><br>
              Comment: <%= review.comment %>
            </li>
            <br>
          <% } %>
        <% }) %>
      <% }) %>
    </ol>

    <br>

    <!-- Pagination controls - only show if there are multiple pages -->
    <% if (totalPages > 1) { %>
      <div>
        <!-- Previous page link - only show if not on first page -->
        <% if (page > 1) { %>
          <a href="/reviews/?page=<%= page - 1 %>">Previous</a>
        <% } %>

        <!-- Current page indicator -->
        Page <%= page %> of <%= totalPages %>

        <!-- Next page link - only show if not on last page -->
        <% if (page < totalPages) { %>
          <a href="/reviews/?page=<%= page + 1 %>">Next</a>
        <% } %>
      </div>
    <% } %>

  <% } %>

</body>
</html>