<html>
<head>
  <title>Events</title>
</head>
<body>

  <% if (eventList.length === 0) { %>
    <p>No events yet.</p>
  <% } else { %>
    <h2>Node.js Event List</h2>
    <a href="/events">back</a><br><br>

    <a href="/events/event-list"><button>Upcoming</button></a>
    <a href="/events/event-list?filter=past"><button>Past</button></a>
    <a href="/events/event-list?filter=attending"><button>Attending</button></a>
     
    <% eventList.forEach(event => { %>
      
        <p><strong>Name: <%= event.name %></strong></p>
        Description: <%= event.desc %><br>
        Date: <%= new Date(event.date).toLocaleDateString('en-GB', {
          day: 'numeric',
          month: 'long',
          year: 'numeric'
        }) %> <%= new Date(event.date).toLocaleTimeString('en-GB', {
          hour: '2-digit',
          minute: '2-digit'
        }) %><br>
        Entry Fee: <%= event.entryFee %><br>
        Location: <%= event.location %><br>
        Participants: <%= event.participants.length %>/<%= event.capacity %><br><br>

        <strong>Also attended by:</strong>
        <% const friendsHere = event.participants.filter(p => followings.some(f => f.toString() === p._id.toString())); %>
        <% if (friendsHere.length > 0) { %>
          <!-- <strong>Mutuals attending:</strong> <%= friendsHere.map(p => p.username).join(', ') %><br> -->
          <% friendsHere.forEach(p => { %>
            <img src="<%= p.profilePicture %>" style="width:24px;height:24px;border-radius:50%;vertical-align:middle;"> <%= p.username %>
          <% }); %>
        <% } %>
        <br><br>
        <% if (event.author && event.author.toString() === userId) { %>
          <button disabled>Your event</button>
        <% } else if (userEvents.some(e => e.toString() === event._id.toString())) { %>
          <form action="/events/event-list/remove" method="POST">
            <input type="hidden" name="eventId" value="<%= event._id %>">
            <button type="submit">Remove from my events</button>
          </form>
        <% } else if (event.participants.length >= event.capacity) { %>
            <button disabled>Event Full</button>
        <% } else if (new Date() > new Date(event.date)) { %>
            <button disabled>Past Event</button>
        <% } else { %>
          <form action="/events/event-list" method="POST">
            <input type="hidden" name="eventId" value="<%= event._id %>">
            <button type="submit">Add to my events</button>
          </form>
        <% } %>

      <hr>
    <% }); %>
    
  <% } %>
     
</body>
</html>