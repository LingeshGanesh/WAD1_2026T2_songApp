<!DOCTYPE html>
<html lang="en">
<head>
  <title>Events</title>
  <link rel="stylesheet" href="/css/events-styles.css">
</head>
<body>
  <%- include("../navbar-user") %>
  <br><br><br>
  <div class="event-list-page">
  <a href="/events" class="back-link">← Back</a>
  <h1>Music is better with friends!!</h1>

  <div class="filter-tabs">
    <a href="/events/event-list"><button class="<%= !filter || filter === 'upcoming' ? 'tab-active' : '' %>">Upcoming</button></a>
    <a href="/events/event-list?filter=past"><button class="<%= filter === 'past' ? 'tab-active' : '' %>">Past</button></a>
    <a href="/events/event-list?filter=attending"><button class="<%= filter === 'attending' ? 'tab-active' : '' %>">Attending</button></a>
  </div>
  <% if (eventList.length === 0) { %>
    <p class="empty-state">No events yet.</p>
  <% } else { %>

     
    <% eventList.forEach(event => { %>
      <div class="event-card">
        <div class="event-card-top">
          <a href="/events/view-event?id=<%= event._id %>" class="event-card-name"><%= event.name %></a>
          <span class="event-card-fee"><%= event.entryFee == 0 ? 'Free' : '$' + event.entryFee %></span>
        </div>
        <div class="event-card-host">
          <img src="<%= event.author.profilePicture %>" style="width:20px;height:20px;border-radius:50%;vertical-align:middle;">
          hosted by: <%= event.author.username %>
          <% const authorIsFollowing = event.author && followings.some(f => f.toString() === event.author._id.toString()); %>
          <% if (authorIsFollowing) { %><span class="follow-badge">· you follow</span><% } %>
        </div>
        <div class="event-card-meta">
          <span><%= event.location %> · <%= new Date(event.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) %> <%= new Date(event.date).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' }) %></span>
          <span><%= event.desc %></span>
          <span>Participants: <%= event.participants.length %>/<%= event.capacity %></span>
        </div>

        <% const friendsHere = event.participants.filter(p => followings.some(f => f.toString() === p._id.toString())); %>
        <% if (friendsHere.length > 0) { %>
          <div class="event-card-friends">
            <span>Also attended by:</span>
            <% friendsHere.forEach(p => { %>
              <img src="<%= p.profilePicture %>" style="width:24px;height:24px;border-radius:50%;vertical-align:middle;"> <%= p.username %>
            <% }); %>
          </div>
        <% } %>
        <br>
        <div class="event-card-actions">
          <% if (event.author && event.author._id.toString() === userId) { %>
            <button disabled>Your event</button>
          <% } else if (new Date() > new Date(event.date)) { %>
            <button disabled>Past Event</button>
          <% } else if (userEvents.some(e => e.toString() === event._id.toString())) { %>
            <form action="/events/event-list/remove" method="POST">
              <input type="hidden" name="eventId" value="<%= event._id %>">
              <button type="submit" class="btn-remove">Remove from my events</button>
            </form>
          <% } else if (event.participants.length >= event.capacity) { %>
            <button disabled>Event Full</button>
          <% } else { %>
            <form action="/events/event-list" method="POST">
              <input type="hidden" name="eventId" value="<%= event._id %>">
              <button type="submit" class="btn-add">Add to my events</button>
            </form>
          <% } %>
        </div>
      </div>
      <% }); %>
  <% } %>
  </div>
  <br><br><br>
</body>
</html>