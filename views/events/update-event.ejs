<!DOCTYPE html>
<html lang="en">
<head>
    <title>Update Event</title>
    <link rel="stylesheet" href="/css/events-styles.css">
</head>
<body>
    <%- include("../navbar-user") %>
    <br><br><br>
    <div class="event-list-page">
    <% if (result.name) { %>
        <a href="/events/user-events" class="back-link">← Back</a>
        <h1>Update Event</h1>

        <form action="/events/update-event" method="POST" class="event-form">
            <input type="hidden" name="name" value="<%= result.name %>">
            <input type="hidden" name="id" value="<%= result._id %>">
            <div class="form-field"><label>Name</label><p><%= result.name %></p></div>
            <div class="form-field"><label>Description</label><input type="text" name="desc" value="<%= result.desc %>"></div>
            <div class="form-field"><label>Date</label><input type="datetime-local" name="date" value="<%= result.date ? new Date(new Date(result.date).getTime() + 8*60*60*1000).toISOString().slice(0, 16) : '' %>"></div>
            <div class="form-field"><label>Entry Fee</label><input type="text" name="entryFee" value="<%= result.entryFee %>"></div>
            <div class="form-field"><label>Location</label><input type="text" name="location" value="<%= result.location %>"></div>
            <div class="form-field"><label>Capacity</label><input type="text" name="capacity" value="<%= result.capacity %>"></div>
            <% if(msg) { %><p class="form-error"><%- msg %></p><% } %>
            <button type="submit" id="submitBtn" disabled>Update Event</button>
        </form>

        <script>
            const form = document.querySelector('form');
            const btn = document.getElementById('submitBtn');
            const original = new FormData(form);

            form.addEventListener('input', () => {
                const current = new FormData(form);
                const changed = [...original.keys()].some(k => original.get(k) !== current.get(k));
                btn.disabled = !changed;
            });
        </script>

    <% } %>
    </div>
    <br><br><br>
</body>
</html>