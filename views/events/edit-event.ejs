<!DOCTYPE html>
<html>
<head>
  <title>Edit Events</title>
  <link rel="stylesheet" href="/css/events-styles.css">
</head>
<body>
  <%- include('../navbar-user') %>
<div style="text-align: left; padding-left: 60px; margin-bottom: 20px;">
  <a href="/events">back</a>
</div>

  <div class="all-events-section">
    <h1 class="all-events-title">MY EVENTS</h1>



    <% if (events.length === 0) { %>
      <p class="no-events-text">No events yet.</p>
    <% } else { %>
      <div class="all-events-cards">
        <% events.forEach(event => { %>
          <div class="all-event-card">
            <h2 class="all-event-name"><%= event.name %></h2>
            <p>
              Date: <%= new Date(event.date).toLocaleDateString('en-GB', {
                day: 'numeric',
                month: 'long',
                year: 'numeric'
              }) %>
            </p>
            <p><%= event.location %></p>
            <p class="all-event-desc"><%= event.desc %></p>
            <p>Entry Fee: <%= event.entryFee %></p>
            <p>
              <a href="/events/update-event?id=<%= event._id %>"><button>Edit</button></a>
              <a href="/events/delete-event?id=<%= event._id %>"><button>Delete</button></a>
            </p>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

  <%- include('../footer') %>
</body>
</html>