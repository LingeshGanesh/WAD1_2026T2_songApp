<!DOCTYPE html>
<html lang="en">
<head>
    <title>Delete Event</title>
    <link rel="stylesheet" href="/css/events-styles.css">
</head>
<body>
    <%- include("../navbar-user") %>
    <br><br><br>
    <div class="event-list-page">
        <a href="/events/user-events" class="back-link">← Back</a>
        <h1>Delete Event</h1>

        <% if (result) { %>
            <div class="event-form">
                <div class="form-field"><label>Name</label><p><%= result.name %></p></div>
                <div class="form-field"><label>Description</label><p><%= result.desc %></p></div>
                <div class="form-field"><label>Date</label><p><%= result.date %></p></div>
                <div class="form-field"><label>Entry Fee</label><p>$<%= result.entryFee %></p></div>
                <div class="form-field"><label>Location</label><p><%= result.location %></p></div>
            </div>
            <form action="/events/delete-event" method="POST" style="margin-top:1rem;width:100%;">
                <input type="hidden" name="id" value="<%= result._id %>">
                <input type="hidden" name="name" value="<%= result.name %>">
                <button type="submit" class="btn-delete">Confirm Delete</button>
            </form>
        <% } else if (result === null) { %>
            <p class="empty-state">Event not found</p>
        <% } %>
    </div>
    <br><br><br>
    <%- include("../footer") %>
</body>
</html>