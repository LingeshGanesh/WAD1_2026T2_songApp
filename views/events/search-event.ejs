<!DOCTYPE html>
<html lang="en">
<head>
    <title>Search Events</title>
    <link rel="stylesheet" href="/css/events-styles.css">
</head>
<body>
    <%- include('../navbar-user') %>

    <div class="all-events-section">
        <div style="text-align: left; padding-left: 60px; margin-bottom: 20px;">
            <a href="/events">back</a>
        </div>

        <h1 class="all-events-title">SEARCH EVENTS</h1>

        <form action="/events/search-event" method="POST" class="search-form">
            <input type="text" name="name" class="search-input" placeholder="Search events...">
            <button type="submit" class="search-button">Find</button>
        </form>

        <% if (searchTerm) { %>
            <p class="no-events-text">Search results for: <%= searchTerm %></p>
        <% } %>

        <% if (result && result.length > 0) { %>
            <div class="all-events-cards">
                <% result.forEach(event => { %>
                    <div class="all-event-card">
                        <h2 class="all-event-name"><%= event.name %></h2>
                        <p>
                            Date: <%= new Date(event.date).toLocaleDateString('en-GB', {
                                day: 'numeric',
                                month: 'long',
                                year: 'numeric'
                            }) %>
                        </p>
                        <p><%= event.location %></p>
                        <p class="all-event-desc"><%= event.desc %></p>
                        <p>Entry Fee: $<%= event.entryFee %></p>
                    </div>
                <% }); %>
            </div>
        <% } else if (result === null || (result && result.length === 0)) { %>
            <p class="no-events-text">Event not found</p>
        <% } %>
    </div>

    <%- include('../footer') %>
</body>
</html>