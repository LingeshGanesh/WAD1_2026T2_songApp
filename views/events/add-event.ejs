<!DOCTYPE html>
<html lang="en">
<head>
    <title>Add a New Event</title>
    <link rel="stylesheet" href="/css/events-styles.css">
</head>
<body>
    <%- include("../navbar-user") %><br><br><br>
    <div class="event-list-page">
        <a href="/events/user-events" class="back-link">← Back</a>
        <h1>Add a New Event</h1>
        <form action="/events/add-event" method="POST" class="event-form">
            <div class="form-field"><label>Name</label><input type="text" name="name"></div>
            <div class="form-field"><label>Description</label><input type="text" name="desc"></div>
            <div class="form-field"><label>Starting Time</label><input type="datetime-local" name="date" min="<%= new Date().toLocaleString('sv', {timeZone: 'Asia/Singapore'}).replace(' ', 'T').slice(0, 16) %>"></div>
            <div class="form-field"><label>Entry Fee</label><input type="text" name="entryFee" min="0"></div>
            <div class="form-field"><label>Location</label><input type="text" name="location"></div>
            <div class="form-field"><label>Capacity</label><input type="number" name="capacity" min="1"></div>
            <% if(msg) { %><p class="form-error"><%- msg %></p><% } %>
            <button type="submit" class="btn-add" style="width:100%;height:48px;font-size:1rem;">Add Event</button>
        </form>
    </div><br><br><br>
</body>
</html>