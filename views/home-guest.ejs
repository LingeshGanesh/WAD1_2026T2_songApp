<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
    <link rel="stylesheet" href="/css/events-styles.css">
</head>
<body class="home-bg">
    <section class="home-hero">
        <h1>Welcome to <br><span class="home-accent">Lowkify!</span></h1>
        <p>
            Browse songs, build playlists, and enjoy a shared music experience with Lowkify.
        </p>
        <p>
            Join <strong><%= stats.user.length %> user<%= stats.user.length == 1? "": "s" %></strong> to listening
            <strong><%= stats.song.length %> song<%= stats.song.length == 1? "": "s" %>!</strong> There are currently
            <strong><%= stats.playlist.length %>+ playlists</strong> posted and shared!
        </p>
        <div class="home-cta-row">
            <a href="/user/register"><button class="home-btn-primary">Register</button></a>
            <a href="/user/login"><button class="home-btn-secondary">Log-In</button></a>
        </div>
    </section>
</body>
</html>