<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Song</title>
    <link rel="stylesheet" href="/css/songs.css">
</head>

<body class="songs-page">
    <%- include("../navbar-user") %>
    <fieldset>
        <legend>Edit Song</legend>
        <!-- Display error message if there is an error -->
        <% if (error) { %>
        <p style="color: red;"><strong>Error:</strong>
            <%= error %>
        </p>
        <% } %>
        <!-- Edit song form pre-filled with existing song data -->
        <form action="/songs/edit/<%= song._id %>" method="post">
            <p><strong>Uploader:</strong>
                <%= song.uploader ? song.uploader.username : "-" %>
            </p>
            <%- include("form-fields", { fields: song, showUploader: false, showAlbum: false }) %>
            <input type="submit" value="Save Changes">
        </form>
    </fieldset>
    <%- include("../footer") %>
</body>

</html>
