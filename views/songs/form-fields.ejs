<!-- Form fields for song data -->

<!-- Determine whether to show uploader and album fields based on passed variables -->
<% const displayUploader = typeof showUploader === "undefined" ? true : showUploader; %>
<% const displayAlbum = typeof showAlbum === "undefined" ? true : showAlbum; %>

<!-- Hidden field for uploader (only shown if showUploader is true) -->
<% if (displayUploader !== false) { %>
<label for="uploader">Uploader</label><br>
<input type="text" name="uploader" id="uploader" value="<%= fields.uploader || '' %>" required><br><br>
<% } %>

<label for="title">Title</label><br>
<input type="text" name="title" id="title" value="<%= fields.title || '' %>" required><br><br>

<label for="artist">Artist</label><br>
<input type="text" name="artist" id="artist" value="<%= fields.artist || '' %>" required><br><br>

<!-- Hidden field for album (only shown if showAlbum is true) -->
<% if (displayAlbum !== false) { %>
<label for="album">Album</label><br>
<input type="text" name="album" id="album" value="<%= fields.album || '' %>"><br><br>
<% } %>

<!-- Genre (selected from a dropdown) -->
<label for="genre">Genre</label><br>
<select name="genre" id="genre">
    <option value="Classical" <%= fields.genre === "Classical" ? "selected" : "" %>>Classical</option>
    <option value="Country" <%= fields.genre === "Country" ? "selected" : "" %>>Country</option>
    <option value="Electronic" <%= fields.genre === "Electronic" ? "selected" : "" %>>Electronic</option>
    <option value="Hip-Hop" <%= fields.genre === "Hip-Hop" ? "selected" : "" %>>Hip-Hop</option>
    <option value="Indie" <%= fields.genre === "Indie" ? "selected" : "" %>>Indie</option>
    <option value="Jazz" <%= fields.genre === "Jazz" ? "selected" : "" %>>Jazz</option>
    <option value="Pop" <%= fields.genre === "Pop" ? "selected" : "" %>>Pop</option>
    <option value="Rock" <%= fields.genre === "Rock" ? "selected" : "" %>>Rock</option>
</select><br><br>

<label for="duration">Duration (seconds)</label><br>
<input type="number" name="duration" id="duration" min="1" value="<%= fields.duration || '' %>" required><br><br>

<label for="youtubeUrl">YouTube URL</label><br>
<input type="url" name="youtubeUrl" id="youtubeUrl" value="<%= fields.youtubeUrl || '' %>"><br><br>
