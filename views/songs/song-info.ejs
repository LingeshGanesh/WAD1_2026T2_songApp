<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= song.title %></title>
    <link rel="stylesheet" href="/css/songs.css">
</head>

<body class="songs-page">
    <%- include("../navbar-user") %>
    <h1><%= song.title %></h1>
    <!-- Song information -->
    <p><strong>Uploaded by:</strong> <%= song.uploader ? song.uploader.username : "-" %></p>
    <p><strong>Artist:</strong> <%= song.artist %></p>
    <p><strong>Album:</strong>
        <% if (song.album && song.album._id) { %>
        <a href="/album/<%= song.album._id %>"><%= song.album.title %></a>
        <% } else { %>
        N/A
        <% } %>
    </p>
    <p><strong>Genre:</strong> <%= song.genre || "N/A" %></p>
    <p><strong>Duration:</strong> <%= formatDuration(song.duration) %></p>
    <p><strong>YouTube URL:</strong>
        <% if (song.youtubeUrl) { %>
        <a href="<%= song.youtubeUrl %>"><%= song.youtubeUrl %></a>
        <% } else { %>
        N/A
        <% } %>
    </p>

    <!-- Action links -->
    <ul>
        <li><a href="/reviews/<%= song._id %>">Review Song</a></li>
        <li><a href="/songs/edit/<%= song._id %>">Edit Song</a></li>
        <li><a href="/songs/delete/<%= song._id %>">Delete Song</a></li>
        <li><a href="/songs/browse">Back to Browse</a></li>
    </ul>
</body>

</html>
